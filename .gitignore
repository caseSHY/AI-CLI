# Tool cache (all caches consolidated here)
.cache/

# Global tool artifacts (from user environment, not project deps)
.benchmarks/

# Python runtime and build output
__pycache__/
*.py[cod]
*.pyo
htmlcov/
build/
dist/
*.egg-info/
.coverage
coverage.xml

# Local environments
.venv/
.venv-wsl/
venv/
env/
.env
.env.*

# Editor and OS noise
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Tool temp directories
.opencode/

# Local upstream GNU Coreutils cache.
# Keep the files locally, but do not publish the vendored tarball/source tree by default.
/project/vendor/gnu-coreutils/coreutils-*/
/project/vendor/gnu-coreutils/*.tar.*

# Dev logs and temporary files
*.log
*.tmp

# Pyenv version pin
.python-version
